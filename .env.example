# macOS code signing + notarization credentials for release builds.
# Copy to .env and fill in your values. Never commit the real .env.
APPLE_ID=your-apple-id@example.com
# Find it at https://developer.apple.com/account (Membership details)
APPLE_TEAM_ID=XXXXXXXXXX
# Create at https://account.apple.com -> Sign-In and Security -> App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Use the Developer ID Application certificate from the login keychain.
CSC_IDENTITY_AUTO_DISCOVERY=true
